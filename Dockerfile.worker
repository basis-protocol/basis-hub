FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY app/ ./app/

CMD ["python", "-c", "import traceback; from app.database import init_pool; init_pool(); import asyncio; from app.worker import run_scoring_cycle; asyncio.run(run_scoring_cycle())"]
